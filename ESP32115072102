  pinMode(I2C_SDA_PIN2, INPUT_PULLUP);
  pinMode(I2C_SCL_PIN2, OUTPUT);
  digitalWrite(I2C_SCL_PIN2, HIGH);
  delayMicroseconds(5);

  if (digitalRead(I2C_SDA_PIN2) == LOW) {
    for (int i = 0; i < 9; i++) {
      digitalWrite(I2C_SCL_PIN2, LOW);
      delayMicroseconds(5);
      digitalWrite(I2C_SCL_PIN2, HIGH);
      delayMicroseconds(5);
    }
  }

  pinMode(I2C_SDA_PIN2, OUTPUT);
  digitalWrite(I2C_SDA_PIN2, LOW);
  delayMicroseconds(5);
  digitalWrite(I2C_SCL_PIN2, HIGH);
