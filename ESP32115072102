// =========================================================================
// 🆕 I2C Bus Recovery
// 用途：當BH1750(0x5C裸版)因供電雜訊/EMI導致SDA被卡在低電位、或整條I2C bus鎖死時,
//      軟體手動打出9個SCL脈衝逼迫從機釋放SDA,再送出STOP條件,最後重新Wire.begin()。
//      這是業界標準的I2C bus recovery流程,無法根治雜訊源頭,但能讓bus在幾十毫秒內
//      恢復可通訊狀態,不必等到手動重開機。
// =========================================================================
void i2cBusRecovery() {
  Wire.end();
  delay(10);

  pinMode(I2C_SDA_PIN, INPUT_PULLUP);
  pinMode(I2C_SCL_PIN, OUTPUT);
  digitalWrite(I2C_SCL_PIN, HIGH);
  delayMicroseconds(5);

  // 若SDA被卡在低電位,打9個SCL脈衝逼迫從機釋放
  if (digitalRead(I2C_SDA_PIN) == LOW) {
    for (int i = 0; i < 9; i++) {
      digitalWrite(I2C_SCL_PIN, LOW);
      delayMicroseconds(5);
      digitalWrite(I2C_SCL_PIN, HIGH);
      delayMicroseconds(5);
    }
  }

  // 手動送出一個STOP條件,結束可能卡住的傳輸(SDA low->high, 同時SCL維持high)
  pinMode(I2C_SDA_PIN, OUTPUT);
  digitalWrite(I2C_SDA_PIN, LOW);
  delayMicroseconds(5);
  digitalWrite(I2C_SCL_PIN, HIGH);
  delayMicroseconds(5);
  digitalWrite(I2C_SDA_PIN, HIGH);
  delayMicroseconds(5);

  // 恢復I2C腳位功能,重新啟動Wire
  Wire.begin(I2C_SDA_PIN, I2C_SCL_PIN);
  delay(50);

  bh1750BareRecoveryTotal++;
  Serial.println("🔧 已執行I2C bus recovery(累計第" + String(bh1750BareRecoveryTotal) + "次)");
}


// 🆕 BH1750(0x5C裸板)專屬第二組I2C bus(GPIO4/5)的recovery,邏輯與主bus版本相同,
