 connectWiFi();


 // 🆕 WiFi連線後同步NTP時間,BH1750日出日落休眠判斷需要準確的即時時間
 configTime(TIMEZONE_OFFSET * 3600, 0, "pool.ntp.org", "time.nist.gov");
 Serial.print("🕐 正在同步NTP時間");
 struct tm timeinfo;
 int ntpRetry = 0;
 while (!getLocalTime(&timeinfo) && ntpRetry < 10) {
   Serial.print(".");
   delay(500);
   ntpRetry++;
 }
 if (getLocalTime(&timeinfo)) {
   Serial.println("\n✅ NTP時間同步成功: " + String(timeinfo.tm_hour) + ":" + String(timeinfo.tm_min));
   computeSunTimesForToday(timeinfo); // 開機時先算好今天的日出日落,避免第一輪循環判斷用到預設值
 } else {
   Serial.println("\n⚠️ NTP時間同步失敗,BH1750休眠判斷將暫用預設安全時段(05:00~19:00),之後每輪會重試取得時間");
 }


 // 開機立即量一次土壤濕度,避免第一筆上傳送出未初始化的0%假資料
 refreshSoilCache();
}




void loop() {
 if (WiFi.status() != WL_CONNECTED) {
   if (wasConnected) { wifiDisconnectCount++; wasConnected = false; }
   static unsigned long lastRetryTime = 0;
   if (millis() - lastRetryTime > 10000) { lastRetryTime = millis(); WiFi.disconnect(); WiFi.begin(ssid, password); }
 } else {
   // 🆕 剛從斷線恢復連線：先把離線期間暫存的資料回補給GAS，再進行本輪的正常上傳
   if (!wasConnected) {
     flushBackfillBuffer();
   }
   wasConnected = true;
 }


 if (millis() - lastUploadTime >= uploadInterval || lastUploadTime == 0) {
   lastUploadTime = millis();
   if (WiFi.status() == WL_CONNECTED) {
     uploadAndCheckCommand();
   } else {
     // 🆕 斷線中：沿用同一個60秒週期，改為背景取樣暫存，而不是整段空窗
     bufferOfflineSample();
   }
 }


 unsigned long now = millis();
 if (relayJActive && (now - relayJStartTime >= relayJDuration)) { digitalWrite(RELAY_J_PIN, HIGH); relayJActive = false; }
 if (relayOActive && (now - relayOStartTime >= relayODuration)) { digitalWrite(RELAY_O_PIN, HIGH); relayOActive = false; }
 if (relayPActive && (now - relayPStartTime >= relayPDuration)) { digitalWrite(RELAY_P_PIN, HIGH); relayPActive = false; }
}




int getSoilAverage(int pin) {
 long sum = 0;
 for (int i = 0; i < 12; i++) { sum += analogRead(pin); delay(5); }
 int rawAvg = sum / 12;
 int percentage = map(rawAvg, AIR_VALUE, WATER_VALUE, 0, 100);
 if (percentage < 0) percentage = 0;
 if (percentage > 100) percentage = 100;
 return percentage;
}




void connectWiFi() {
 WiFi.begin(ssid, password);
 Serial.print("📡 Wi-Fi 連線中...");
 unsigned long startAttemptTime = millis();
 while (WiFi.status() != WL_CONNECTED && millis() - startAttemptTime < 15000) { delay(500); Serial.print("."); }
 if (WiFi.status() == WL_CONNECTED) Serial.println("\n✅ Wi-Fi 已成功連線！");
}


// =========================================================================
// 🆕 OTA 韌體更新：透過Cloudflare Worker轉發Drive上的firmware.bin,
// 不再經過GAS中繼+Base64編碼,直接下載原始二進位檔案寫入更新分區。
//
// 🔧 安全性修正：原本 client.setInsecure() 會完全跳過TLS憑證驗證，
// 任何人只要能劫持DNS/網路路徑(例如同一WiFi下的中間人攻擊)就能偽裝成
// OTA伺服器、發送惡意韌體，ESP32毫無防備地就會安裝。
// 改成優先用 setCACert() 驗證憑證鏈；只有在還沒填入根憑證(OTA_ROOT_CA_PEM留空)
// 時才退回 setInsecure() 並印出明顯警告，方便你先用舊行為驗證整個OTA流程沒問題，
// 之後再補上憑證即可切換成安全模式，不會因為漏填憑證就直接卡死升級不了。
// =========================================================================
void performOTAUpdate(String targetVersion) {
 Serial.println("🔄 收到OTA指令,目標版本：" + targetVersion + "（目前版本：" + FIRMWARE_VERSION + "）");

 WiFiClientSecure client;

 // 🆕 修正：原本沒有設定逾時，若下載中途網路卡頓/半死不活，httpUpdate.update()
 // 可能永遠卡住不返回，ESP32就會停在OTA這一步、不再回到loop()打卡，
 // GAS端的5分鐘逾時判斷也因為收不到打卡而永遠不會被觸發，導致「⏳下載中」狀態卡死。
 // 30秒沒有任何資料進來就會判定連線逾時、讓 httpUpdate.update() 返回失敗，
 // 之後會自動重啟繼續走正常流程，下次打卡GAS就能依照原本的5分鐘機制判斷逾時重試或失敗。
 client.setTimeout(30000);

 bool useSecureCert = (OTA_ROOT_CA_PEM != nullptr && strlen(OTA_ROOT_CA_PEM) > 0);
 if (useSecureCert) {
   client.setCACert(OTA_ROOT_CA_PEM);
   Serial.println("🔒 OTA使用憑證鏈驗證(setCACert)，將拒絕憑證不符的連線");
 } else {
   client.setInsecure();
   Serial.println("⚠️ 尚未設定 OTA_ROOT_CA_PEM，OTA暫時退回不驗證憑證模式(setInsecure)，"
                   "建議盡快依程式碼註解說明取得根憑證並填入，降低中間人攻擊風險");
 }

 httpUpdate.rebootOnUpdate(true); // 更新成功後自動重啟,套用新韌體

 t_httpUpdate_return ret = httpUpdate.update(client, OTA_WORKER_URL);
 switch (ret) {
   case HTTP_UPDATE_FAILED:
     Serial.printf("❌ OTA失敗 (%d): %s\n", httpUpdate.getLastError(), httpUpdate.getLastErrorString().c_str());
     break;
   case HTTP_UPDATE_NO_UPDATES:
     Serial.println("⚠️ OTA:Worker回應沒有可更新內容");
     break;
   case HTTP_UPDATE_OK:
     Serial.println("✅ OTA成功,即將自動重啟套用新版本");
     break;
 }
}




// 統一的啟動澆水函式：記錄驗證起始濕度、啟動繼電器、開啟2分鐘驗證窗
void startWatering(int relayPin, bool &active, unsigned long &startTime, unsigned long &duration,
                   unsigned long ms, int freshSoilValue, int &soilAtStart,
                   unsigned long &verifyEnd, bool &verifyPending) {
 soilAtStart = freshSoilValue;
 digitalWrite(relayPin, LOW);
 active = true;
 startTime = millis();
 duration = ms;
 verifyEnd = millis() + 120000; // 啟動後2分鐘進行驗證
 verifyPending = true;
}




// =========================================================================
// 🆕 統一封裝感測器讀值＋BH1750日出日落休眠/recovery狀態機＋異常訊息組合，
// 供「正常上傳」與「離線背景取樣」共用，確保兩種情境下感測器狀態(休眠中/recovery/失敗計數)
// 是同一份狀態機在推進，不會因為離線而各自跑出不一致的行為。
// 注意：土壤濕度不在這裡量測，由呼叫端決定要用快取值還是強制重測後傳入。
// =========================================================================
SensorReading collectSensorReading(int soilJ, int soilO, int soilP,
                                    unsigned long soilAgeJ, unsigned long soilAgeO, unsigned long soilAgeP) {
 SensorReading r;
 r.soilJ = soilJ; r.soilO = soilO; r.soilP = soilP;
 r.soilAgeJ = soilAgeJ; r.soilAgeO = soilAgeO; r.soilAgeP = soilAgeP;

 sensors_event_t humidity, temp;
 bool ahtValid = aht.getEvent(&humidity, &temp);
 r.temp = temp.temperature;
 r.hum  = humidity.relative_humidity;
 r.pres = bmp.readPressure() / 100.0F;

 struct tm timeinfo;
 bool haveTime = getLocalTime(&timeinfo, 3000);
 if (haveTime && lastSunCalcYday != timeinfo.tm_yday) {
   computeSunTimesForToday(timeinfo); // 日期變更(過了午夜)，重新計算今天的日出日落時刻
 }
 // 🆕 用time(nullptr)取得UTC epoch，而非用mktime(&timeinfo)反推，
 //    避免ESP32未設定POSIX TZ字串時mktime對時區假設不一致、回補時間戳偏差整個時區的風險。
 r.ts = haveTime ? time(nullptr) : 0;

 if (lightSensorAsleep) {
   // 休眠中不進行量測，直接用-2標記「感測器未開啟」，GAS端需辨識這個特殊值
   r.light = -2;
   r.light2 = lightMeter2Ready ? -2 : -1;
   if (haveTime) {
     int nowMinute = timeinfo.tm_hour * 60 + timeinfo.tm_min;
     bool inNightWindow = (nowMinute >= sleepEligibleMinuteOfDay) || (nowMinute < wakeMinuteOfDay);
     if (!inNightWindow) { wakeLightSensor(); }
   }
 } else {
   r.light = lightMeter.readLightLevel();

   if (lightMeter2Ready) {
     r.light2 = lightMeter2.readLightLevel();
     if (r.light2 < 0) {
       bh1750BareFailCount++;
       Serial.println("⚠️ BH1750(0x5C)讀取失敗,連續累計:" + String(bh1750BareFailCount) + "次");
       if (bh1750BareFailCount >= MAX_FAIL_BEFORE_RECOVERY) {
         i2cBusRecovery2_();
         if (lightMeter2.begin(BH1750::CONTINUOUS_HIGH_RES_MODE, 0x5C, &I2CTwo)) {
           lightMeter2.setMTreg(31);
           Serial.println("✅ BH1750(0x5C) recovery後重新初始化成功");
         } else {
           Serial.println("❌ BH1750(0x5C) recovery後仍初始化失敗,下次上傳週期會再嘗試");
           lightMeter2Ready = false;
         }
         bh1750BareFailCount = 0;
       }
     } else {
       bh1750BareFailCount = 0;
     }
   } else {
     r.light2 = -1;
     bh1750BareInitRetryCount++;
     if (bh1750BareInitRetryCount >= INIT_RETRY_INTERVAL) {
       bh1750BareInitRetryCount = 0;
       Serial.println("🔧 定期重試:嘗試重新初始化BH1750(0x5C)...");
       i2cBusRecovery2_();
       if (lightMeter2.begin(BH1750::CONTINUOUS_HIGH_RES_MODE, 0x5C, &I2CTwo)) {
         lightMeter2.setMTreg(31);
         lightMeter2Ready = true;
         bh1750BareFailCount = 0;
         Serial.println("✅ BH1750(0x5C) 定期重試初始化成功！");
       } else {
         Serial.println("❌ BH1750(0x5C) 定期重試仍失敗");
       }
     }
   }

   if (haveTime && r.light >= 0 && r.light < LUX_SLEEP_THRESHOLD) {
     int nowMinute = timeinfo.tm_hour * 60 + timeinfo.tm_min;
     bool inNightWindow = (nowMinute >= sleepEligibleMinuteOfDay) || (nowMinute < wakeMinuteOfDay);
     if (inNightWindow) { sleepLightSensor(); }
   }
 }

 String statusMessage = "正常";
 String errorDetail = "";
 if (!ahtValid || isnan(r.temp)) errorDetail += "AHT20溫度異常;";
 if (isnan(r.hum))               errorDetail += "AHT20濕度異常;";
 if (r.pres <= 0)                errorDetail += "BMP280氣壓異常;";
 if (!lightSensorAsleep && r.light < 0) errorDetail += "BH1750(0x23)光照異常;";
 if (!lightMeter2Ready)                         errorDetail += "BH1750(0x5C)初始化失敗;";
 else if (!lightSensorAsleep && r.light2 < 0)   errorDetail += "BH1750(0x5C)光照異常;";

 if (errorDetail != "") {
   statusMessage = "感測器異常:" + errorDetail;
 }
 r.statusMessage = statusMessage;
 return r;
}


// 🆕 將一筆記錄寫入環形緩衝區；滿了就覆蓋最舊的一筆(FIFO)，並在Serial留下警告
void pushBackfillRecord(const BackfillRecord &rec) {
 backfillBuffer[backfillHead] = rec;
 backfillHead = (backfillHead + 1) % BACKFILL_MAX;
 if (backfillCount < BACKFILL_MAX) {
   backfillCount++;
 } else {
   Serial.println("⚠️ 斷線回補緩衝區已滿(" + String(BACKFILL_MAX) + "筆)，開始覆蓋最舊資料，較舊的離線資料將遺失");
 }
}


// 🆕 WiFi斷線期間的背景取樣：沿用與正常上傳相同的60秒週期，
//    土壤濕度不重新通電量測(沿用快取，避免無人看管時頻繁通斷探針繼電器)，
//    其餘感測器照常讀取，暫存進環形緩衝區，等重新連線後統一回補。
void bufferOfflineSample() {
 unsigned long nowMs = millis();
 unsigned long soilAgeJ = (nowMs - soilReadTimeJ) / 1000;
 unsigned long soilAgeO = (nowMs - soilReadTimeO) / 1000;
 unsigned long soilAgeP = (nowMs - soilReadTimeP) / 1000;

 SensorReading r = collectSensorReading(cachedSoilJ, cachedSoilO, cachedSoilP, soilAgeJ, soilAgeO, soilAgeP);

 BackfillRecord rec;
 rec.ts = r.ts;
 rec.temp = r.temp; rec.hum = r.hum; rec.pres = r.pres;
 rec.light = r.light; rec.light2 = r.light2;
 rec.soilJ = r.soilJ; rec.soilO = r.soilO; rec.soilP = r.soilP;
 rec.soilAgeJ = r.soilAgeJ; rec.soilAgeO = r.soilAgeO; rec.soilAgeP = r.soilAgeP;
 r.statusMessage.toCharArray(rec.statusMessage, sizeof(rec.statusMessage));
 rec.valid = true;

 pushBackfillRecord(rec);
 Serial.println("💾 WiFi離線中，已暫存離線資料(緩衝區目前" + String(backfillCount) + "/" + String(BACKFILL_MAX) + "筆)" +
                 (r.ts == 0 ? "，⚠️尚無有效時間戳(NTP尚未同步)" : ""));
}


// 🆕 重新連線後，把緩衝區內容依時間先後(最舊的先送)逐筆補傳給GAS。
//    每筆之間間隔300ms，避免瞬間連續高頻請求對GAS/ESP32造成負擔。
//
// 🔧 修正：原本不管上傳成功或失敗，這筆都會被視為「已送出」而從緩衝區移除，
//    等於連線不穩、GAS回應UNAUTHORIZED、或伺服器暫時錯誤時，資料會直接遺失、不會重試。
//    改成：只有明確拿到 httpCode>0 且回應不是 "UNAUTHORIZED" 才視為成功、才會被移出緩衝區；
//    一旦某一筆失敗就立刻停止本次回補迴圈(不繼續送後面的)，維持「最舊的資料一定排在最前面」，
//    避免中間插斷、順序錯亂；下次連線恢復(或下一輪loop判斷WiFi仍connected)會再重新嘗試，
//    失敗的資料永遠留在緩衝區內，直到成功送出，或緩衝區真的滿了才會依照 pushBackfillRecord()
//    既有的FIFO規則覆蓋最舊的一筆。
void flushBackfillBuffer() {
 if (backfillCount == 0) return;

 Serial.println("📤 WiFi已恢復，開始回補離線期間累積的 " + String(backfillCount) + " 筆資料...");
 int oldestIndex = (backfillHead - backfillCount + BACKFILL_MAX) % BACKFILL_MAX;
 int totalToSend = backfillCount;
 int successCount = 0; // 從最舊端開始「連續成功」的筆數，只有這些才會被移出緩衝區

 for (int i = 0; i < totalToSend; i++) {
   if (WiFi.status() != WL_CONNECTED) {
     Serial.println("⚠️ 回補中途WiFi又斷線，剩餘 " + String(totalToSend - successCount) + " 筆留待下次恢復連線後繼續");
     break;
   }

   int idx = (oldestIndex + i) % BACKFILL_MAX;
   BackfillRecord &rec = backfillBuffer[idx];

   if (!rec.valid || rec.ts == 0) {
     // 沒有有效時間戳(取樣當下NTP還沒同步過)，這筆本來就無法正確回補，視為處理完畢後跳過，
     // 但不影響後面資料，繼續往下一筆送。
     Serial.println("  ⚠️ 第 " + String(i + 1) + "/" + String(totalToSend) + " 筆缺少有效時間戳，略過(不會重試這一筆)");
     successCount++;
     continue;
   }

   String url = GAS_URL + "?key="   + WEB_API_KEY +
                          "&fwver=" + FIRMWARE_VERSION +
                          "&backfill=1" +
                          "&ts="    + String((unsigned long)rec.ts) +
                          "&temp="  + String(rec.temp) +
                          "&hum="   + String(rec.hum) +
                          "&pres="  + String(rec.pres) +
                          "&light=" + String(rec.light) +
                          "&light2=" + String(rec.light2) +
                          "&soilJ=" + String(rec.soilJ) +
                          "&soilO=" + String(rec.soilO) +
                          "&soilP=" + String(rec.soilP) +
                          "&soilAgeJ=" + String(rec.soilAgeJ) +
                          "&soilAgeO=" + String(rec.soilAgeO) +
                          "&soilAgeP=" + String(rec.soilAgeP) +
                          "&status=" + urlencode(String(rec.statusMessage));

   HTTPClient http;
   http.begin(url);
   http.setTimeout(15000);
   http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
   int httpCode = http.GET();
   String response = "";
   if (httpCode > 0) {
     response = http.getString();
     response.trim();
   }
   http.end();

   bool success = (httpCode > 0) && (response != "UNAUTHORIZED");

   if (success) {
     Serial.println("  ✅ 回補第 " + String(i + 1) + "/" + String(totalToSend) + " 筆成功(時間戳:" + String((unsigned long)rec.ts) + ")");
     successCount++;
   } else {
     Serial.println("  ❌ 回補第 " + String(i + 1) + "/" + String(totalToSend) + " 筆失敗(HTTP:" + String(httpCode) +
                     (response.length() ? (",回應:" + response) : "") + ")，保留在緩衝區稍後重試，本次回補中止");
     break; // 保持時間先後順序，一旦失敗就停止，避免後面的資料先被送出、順序錯亂
   }
   delay(300);
 }

 if (successCount > 0) {
   backfillCount -= successCount;
   if (backfillCount <= 0) {
     backfillCount = 0;
     backfillHead = 0;
     Serial.println("✅ 離線回補完成，緩衝區已清空");
   } else {
     Serial.println("ℹ️ 本次成功回補 " + String(successCount) + " 筆，緩衝區保留剩餘 " + String(backfillCount) + " 筆待下次連線恢復繼續回補");
   }
 } else {
   Serial.println("⚠️ 本次回補沒有任何一筆成功，緩衝區維持不變，下次連線恢復會重新嘗試");
 }
}


void uploadAndCheckCommand() {
 unsigned long nowMs = millis();


 // 土壤濕度快取邏輯：平時每10分鐘才重新量測一次;
 // 但只要有任一株正在澆水驗證窗期間(verifyPending),就強制每次都重新量測,確保驗證比對用的是即時真實值
 bool needFresh = (nowMs - lastSoilReadTime >= soilReadInterval) || verifyPendingJ || verifyPendingO || verifyPendingP;
 if (needFresh) { refreshSoilCache(); }
 int soilJ = cachedSoilJ;
 int soilO = cachedSoilO;
 int soilP = cachedSoilP;


 // 澆水驗證：啟動滿2分鐘後,比對濕度是否上升超過5%,沒有就鎖定該株馬達2小時
 if (verifyPendingJ && nowMs >= verifyEndJ) {
   int riseJ = soilJ - soilAtWaterStartJ;
   if (riseJ < 5) { motorLockUntilJ = nowMs + (2UL * 60UL * 60UL * 1000UL); Serial.println("🚨 [茉莉] 澆水後濕度上升不足5%，判定失敗，鎖定2小時"); }
   else { Serial.println("✅ [茉莉] 澆水驗證通過，濕度上升 " + String(riseJ) + "%"); }
   verifyPendingJ = false;
 }
 if (verifyPendingO && nowMs >= verifyEndO) {
   int riseO = soilO - soilAtWaterStartO;
   if (riseO < 5) { motorLockUntilO = nowMs + (2UL * 60UL * 60UL * 1000UL); Serial.println("🚨 [桂花] 澆水後濕度上升不足5%，判定失敗，鎖定2小時"); }
   else { Serial.println("✅ [桂花] 澆水驗證通過，濕度上升 " + String(riseO) + "%"); }
   verifyPendingO = false;
 }
 if (verifyPendingP && nowMs >= verifyEndP) {
   int riseP = soilP - soilAtWaterStartP;
   if (riseP < 5) { motorLockUntilP = nowMs + (2UL * 60UL * 60UL * 1000UL); Serial.println("🚨 [朝天椒] 澆水後濕度上升不足5%，判定失敗，鎖定2小時"); }
   else { Serial.println("✅ [朝天椒] 澆水驗證通過，濕度上升 " + String(riseP) + "%"); }
   verifyPendingP = false;
 }


 // 各株土壤資料的新鮮度(秒)：這筆濕度數值是幾秒前實際量測的
 unsigned long soilAgeJ = (nowMs - soilReadTimeJ) / 1000;
 unsigned long soilAgeO = (nowMs - soilReadTimeO) / 1000;
 unsigned long soilAgeP = (nowMs - soilReadTimeP) / 1000;


 // 🆕 感測器讀值/BH1750休眠與recovery狀態機/異常訊息組合，改由collectSensorReading()統一處理，
 // 與離線背景取樣(bufferOfflineSample)共用同一份邏輯，避免兩處各自維護、行為不一致。
 SensorReading r = collectSensorReading(soilJ, soilO, soilP, soilAgeJ, soilAgeO, soilAgeP);
 float envTemp = r.temp, envHum = r.hum, envPres = r.pres, envLight = r.light, envLight2 = r.light2;

 String statusMessage = r.statusMessage;
 if (statusMessage == "正常" && wifiDisconnectCount > 0) {
   statusMessage = "正常(重連:" + String(wifiDisconnectCount) + "次)";
 }


 // 帶有金鑰驗證的正規上傳網址
 String url = GAS_URL + "?key="   + WEB_API_KEY +
                        "&fwver=" + FIRMWARE_VERSION +
                        "&temp="  + String(envTemp) +
                        "&hum="   + String(envHum) +
                        "&pres="  + String(envPres) +
                        "&light=" + String(envLight) +
                        "&light2=" + String(envLight2) +
                        "&soilJ=" + String(soilJ) +
                        "&soilO=" + String(soilO) +
                        "&soilP=" + String(soilP) +
                        "&soilAgeJ=" + String(soilAgeJ) +
                        "&soilAgeO=" + String(soilAgeO) +
                        "&soilAgeP=" + String(soilAgeP) +
                        "&status=" + urlencode(statusMessage);


 Serial.println("🚀 正在將數據上傳至 Google 戰情室...");
 HTTPClient http;
 http.begin(url);
 http.setTimeout(30000);
 http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
 int httpCode = http.GET();
 if (httpCode > 0) {
   String response = http.getString();
   response.trim();
   Serial.println("📥 雲端控制碼回傳: [" + response + "]");


   if (response == "CMD_RESET") {
     // 休眠30秒後自動重新開機,取代原本立即重開機。
     // 進入deep sleep後CPU完全斷電休眠,計時器喚醒時等同於重新執行setup(),
     // 效果上就是「休眠30秒→重新開機」,繼電器等腳位狀態也會在setup()裡重新初始化為關閉。
     Serial.println("💤 收到遠端重置指令,進入深度睡眠30秒後自動重新開機...");
     WiFi.disconnect(true);
     delay(200);
     esp_sleep_enable_timer_wakeup(30ULL * 1000000ULL); // 30秒,單位為微秒
     esp_deep_sleep_start();
   }
   // 🆕 收到OTA更新指令
   else if (response.startsWith("CMD_OTA:")) {
     String targetVersion = response.substring(8); // 取"CMD_OTA:"後面的版本字串
     // 🔧 先結束這條上傳用的連線,再開始OTA下載,避免兩條TLS連線(GAS上傳+OTA下載)同時佔用RAM,
     // 降低長時間運作後heap較緊繃時OTA下載中途失敗的風險。performOTAUpdate()成功會直接重開機,
     // 失敗則直接return,不會再執行到下面的http.end()(已在這裡結束過,不會重複呼叫)。
     http.end();
     performOTAUpdate(targetVersion);
     return;
   }
   // 明確攔截金鑰驗證失敗回應,拒絕滑入自動澆水邏輯,防止資訊中斷
   else if (response == "UNAUTHORIZED") {
     Serial.println("🚨 [核心錯誤] 雲端金鑰驗證失敗！請立刻檢查 ESP32 與 GAS 的 WEB_API_KEY 是否一致！");
   }
   // 以下六個手動指令觸發的單獨重測,探針電源由RELAY_4_PIN統一控管,這裡一樣要包進開電/斷電
   else if (response == "PUMP_J") { probesPowerOn(); int f = getSoilAverage(SOIL_J_PIN); probesPowerOff(); cachedSoilJ = f; soilReadTimeJ = millis(); startWatering(RELAY_J_PIN, relayJActive, relayJStartTime, relayJDuration, 5000, f, soilAtWaterStartJ, verifyEndJ, verifyPendingJ); }
   else if (response == "WASH_J") { probesPowerOn(); int f = getSoilAverage(SOIL_J_PIN); probesPowerOff(); cachedSoilJ = f; soilReadTimeJ = millis(); startWatering(RELAY_J_PIN, relayJActive, relayJStartTime, relayJDuration, 30000, f, soilAtWaterStartJ, verifyEndJ, verifyPendingJ); }
   else if (response == "PUMP_O") { probesPowerOn(); int f = getSoilAverage(SOIL_O_PIN); probesPowerOff(); cachedSoilO = f; soilReadTimeO = millis(); startWatering(RELAY_O_PIN, relayOActive, relayOStartTime, relayODuration, 5000, f, soilAtWaterStartO, verifyEndO, verifyPendingO); }
   else if (response == "WASH_O") { probesPowerOn(); int f = getSoilAverage(SOIL_O_PIN); probesPowerOff(); cachedSoilO = f; soilReadTimeO = millis(); startWatering(RELAY_O_PIN, relayOActive, relayOStartTime, relayODuration, 30000, f, soilAtWaterStartO, verifyEndO, verifyPendingO); }
   else if (response == "PUMP_P") { probesPowerOn(); int f = getSoilAverage(SOIL_P_PIN); probesPowerOff(); cachedSoilP = f; soilReadTimeP = millis(); startWatering(RELAY_P_PIN, relayPActive, relayPStartTime, relayPDuration, 5000, f, soilAtWaterStartP, verifyEndP, verifyPendingP); }
   else if (response == "WASH_P") { probesPowerOn(); int f = getSoilAverage(SOIL_P_PIN); probesPowerOff(); cachedSoilP = f; soilReadTimeP = millis(); startWatering(RELAY_P_PIN, relayPActive, relayPStartTime, relayPDuration, 30000, f, soilAtWaterStartP, verifyEndP, verifyPendingP); }
   else {
     // 自動澆水判斷：改用「快取值」判斷是否要澆水,不再每次上傳(60秒)都強制重新通電量測。
     // 真正需要「即時新鮮值」的時刻(開機、指令觸發、驗證窗期間)已經由 refreshSoilCache()/needFresh 涵蓋,不受影響。
     if (!relayJActive && nowMs >= motorLockUntilJ) {
       if (soilJ < 30) startWatering(RELAY_J_PIN, relayJActive, relayJStartTime, relayJDuration, 5000, soilJ, soilAtWaterStartJ, verifyEndJ, verifyPendingJ);
     }
     if (!relayOActive && nowMs >= motorLockUntilO) {
       if (soilO < 30) startWatering(RELAY_O_PIN, relayOActive, relayOStartTime, relayODuration, 5000, soilO, soilAtWaterStartO, verifyEndO, verifyPendingO);
     }
     if (!relayPActive && nowMs >= motorLockUntilP) {
       if (soilP < 30) startWatering(RELAY_P_PIN, relayPActive, relayPStartTime, relayPDuration, 5000, soilP, soilAtWaterStartP, verifyEndP, verifyPendingP);
     }
   }
 }
 http.end();
}




String urlencode(String str) {
 String encodedString = ""; char c; char code0; char code1;
 for (int i = 0; i < str.length(); i++) {
   c = str.charAt(i);
   if (isalnum(c)) { encodedString += c; }
   else {
     code1 = (c & 0xf) + '0'; if ((c & 0xf) > 9) code1 = (c & 0xf) - 10 + 'A';
     c = (c >> 4) & 0xf; code0 = c + '0'; if (c > 9) code0 = c - 10 + 'A';
     encodedString += '%'; encodedString += code0; encodedString += code1;
   }
 }
 return encodedString;
}
