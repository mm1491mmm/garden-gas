  bh1750BareRecoveryTotal++;
  Serial.println("🔧 已執行BH1750(0x5C)獨立bus recovery(累計第" + String(bh1750BareRecoveryTotal) + "次)");
}




// =========================================================================
// 🆕 太陽仰角計算(NOAA簡化演算法,與GAS端calculateSolarElevation_邏輯一致)
// =========================================================================
int dayOfYearCalc(int year, int month, int day) {
 int daysInMonth[] = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
 bool leap = (year % 4 == 0 && (year % 100 != 0 || year % 400 == 0));
 if (leap) daysInMonth[1] = 29;
 int doy = day;
 for (int i = 0; i < month - 1; i++) doy += daysInMonth[i];
 return doy;
}


float calcSolarElevation(int year, int month, int day, double hourDecimal, double lat, double lon, int tzOffset) {
 int dayOfYear = dayOfYearCalc(year, month, day);
 double gamma = (2.0 * PI / 365.0) * (dayOfYear - 1 + (hourDecimal - 12.0) / 24.0);


 double eqtime = 229.18 * (0.000075 + 0.001868 * cos(gamma) - 0.032077 * sin(gamma)
                  - 0.014615 * cos(2 * gamma) - 0.040849 * sin(2 * gamma));
 double decl = 0.006918 - 0.399912 * cos(gamma) + 0.070257 * sin(gamma)
               - 0.006758 * cos(2 * gamma) + 0.000907 * sin(2 * gamma)
               - 0.002697 * cos(3 * gamma) + 0.00148 * sin(3 * gamma);


 double timeOffset = eqtime + 4 * lon - 60 * tzOffset;
 double trueSolarTime = hourDecimal * 60.0 + timeOffset;
 double hourAngle = (trueSolarTime / 4.0) - 180.0;


 double latRad = lat * PI / 180.0;
 double haRad = hourAngle * PI / 180.0;


 double cosZenith = sin(latRad) * sin(decl) + cos(latRad) * cos(decl) * cos(haRad);
 if (cosZenith > 1) cosZenith = 1;
 if (cosZenith < -1) cosZenith = -1;
 double zenithRad = acos(cosZenith);
 return 90.0 - (zenithRad * 180.0 / PI);
}


// 掃描今天0:00~23:59每一分鐘的太陽仰角,找出日出/日落時刻(分鐘數),
// 再前後各加30分鐘緩衝,算出實際的喚醒時刻/允許休眠時刻。
// 一天只需要執行一次(日期變更時觸發),1440次三角函數運算對ESP32來說負擔很小。
void computeSunTimesForToday(struct tm &timeinfo) {
 int year = timeinfo.tm_year + 1900;
 int month = timeinfo.tm_mon + 1;
 int day = timeinfo.tm_mday;


 int firstUp = -1, lastUp = -1;
 bool prevAbove = false;


 for (int m = 0; m < 1440; m++) {
   double hourDecimal = m / 60.0;
   float elev = calcSolarElevation(year, month, day, hourDecimal, SENSOR_LAT, SENSOR_LON, TIMEZONE_OFFSET);
   bool above = (elev > 0);
   if (above && !prevAbove && firstUp == -1) firstUp = m;
   if (above) lastUp = m;
   prevAbove = above;
 }


 if (firstUp == -1 || lastUp == -1) {
   // 理論上台灣緯度不會發生永晝/永夜,這裡只是防呆,給一組保守安全值
   wakeMinuteOfDay = 5 * 60;
   sleepEligibleMinuteOfDay = 19 * 60;
   Serial.println("⚠️ 太陽仰角掃描異常,套用預設安全時段(05:00~19:00)");
 } else {
   wakeMinuteOfDay = firstUp - SUN_TIME_BUFFER_MIN;
   sleepEligibleMinuteOfDay = lastUp + SUN_TIME_BUFFER_MIN;
   Serial.println("☀️ 今日日出約 " + String(firstUp / 60) + ":" + String(firstUp % 60) +
                   "，日落約 " + String(lastUp / 60) + ":" + String(lastUp % 60));
   Serial.println("   → 喚醒時刻：" + String(wakeMinuteOfDay / 60) + ":" + String(wakeMinuteOfDay % 60) +
                   "，允許休眠時刻：" + String(sleepEligibleMinuteOfDay / 60) + ":" + String(sleepEligibleMinuteOfDay % 60));
 }
 lastSunCalcYday = timeinfo.tm_yday;
}


